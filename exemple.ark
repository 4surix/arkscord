# ArkScript 4.5.0
# ----------------------------------------------------------------------------

(import std.IO)

(import arkscord.client)


(let token (io:readFile ".token"))

(let bot (client:createBot token))

(bot.listenChannelsIds [
    "779683200607715350"
])

(bot.onMessage (fun (message) {
  (print message.author.name ": " message.content)

  (if (= message.content "!stop")
  	(bot.stop) ) }))

(bot.run)
